# Copy this to .env.production and fill in real URLs before deploying the frontend

# Spring Boot backend URL (e.g. your Render backend service)
VITE_API_BASE_URL=https://your-backend.onrender.com/api

# Node.js execution service URL (e.g. your Render execution service)
VITE_EXEC_SERVICE_URL=https://your-execution-service.onrender.com
